<h1>
  Recipe comment #<%= @the_recipe_comment.id %> details
</h1>

<article>
  <div>
    <a href="/recipe_comments">
      Go back
    </a>
  </div>

  <div>
    <a href="/delete_recipe_comment/<%= @the_recipe_comment.id %>">
      Delete recipe comment
    </a>
  </div>
  <dl>
    <dt>
      User
    </dt>
    <dd>
      <%= @the_recipe_comment.user_id %>
    </dd>

    <dt>
      Recipe
    </dt>
    <dd>
      <%= @the_recipe_comment.recipe_id %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_comment.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_comment.updated_at) %> ago
    </dd>
  </dl>
</article>

<hr>


<article>
  <header>
    <h2>
      Edit recipe comment
    </h2>
  </header>

  <form action="/modify_recipe_comment/<%= @the_recipe_comment.id %>"  method="post" >
    <div>
      <label for="user_id_box">
        User
      </label>

      <input type="text" id="user_id_box" name="query_user_id" value="<%= @the_recipe_comment.user_id %>">
    </div>

    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id" value="<%= @the_recipe_comment.recipe_id %>">
    </div>

    <button type="submit">
      Update recipe comment
    </button>
  </form>
</article>

<hr>
