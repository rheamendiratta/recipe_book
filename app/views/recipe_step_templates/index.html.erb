<h1>
  List of all recipe steps
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new recipe step
    </h2>
  </header>

  <form action="/insert_recipe_step" method="post">
    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id">
    </div>

    <div>
      <label for="component_id_box">
        Component
      </label>

      <input type="text" id="component_id_box" name="query_component_id">
    </div>

    <div>
      <label for="step_number_box">
        Step number
      </label>

      <input type="text" id="step_number_box" name="query_step_number">
    </div>

    <div>
      <label for="instruction_box">
        Instruction
      </label>

      <input type="text" id="instruction_box" name="query_instruction">
    </div>

    <button type="submit">
      Create recipe step
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_recipe_steps.each do |a_recipe_step| %>
      <li>
        <a href="/recipe_steps/<%= a_recipe_step.id %>">
          Recipe step #<%= a_recipe_step.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
