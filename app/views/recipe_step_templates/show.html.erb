<h1>
  Recipe step #<%= @the_recipe_step.id %> details
</h1>

<article>
  <div>
    <a href="/recipe_steps">
      Go back
    </a>
  </div>

  <div>
    <a href="/delete_recipe_step/<%= @the_recipe_step.id %>">
      Delete recipe step
    </a>
  </div>
  <dl>
    <dt>
      Recipe
    </dt>
    <dd>
      <%= @the_recipe_step.recipe_id %>
    </dd>

    <dt>
      Component
    </dt>
    <dd>
      <%= @the_recipe_step.component_id %>
    </dd>

    <dt>
      Step number
    </dt>
    <dd>
      <%= @the_recipe_step.step_number %>
    </dd>

    <dt>
      Instruction
    </dt>
    <dd>
      <%= @the_recipe_step.instruction %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_step.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_step.updated_at) %> ago
    </dd>
  </dl>
</article>

<hr>


<article>
  <header>
    <h2>
      Edit recipe step
    </h2>
  </header>

  <form action="/modify_recipe_step/<%= @the_recipe_step.id %>"  method="post" >
    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id" value="<%= @the_recipe_step.recipe_id %>">
    </div>

    <div>
      <label for="component_id_box">
        Component
      </label>

      <input type="text" id="component_id_box" name="query_component_id" value="<%= @the_recipe_step.component_id %>">
    </div>

    <div>
      <label for="step_number_box">
        Step number
      </label>

      <input type="text" id="step_number_box" name="query_step_number" value="<%= @the_recipe_step.step_number %>">
    </div>

    <div>
      <label for="instruction_box">
        Instruction
      </label>

      <input type="text" id="instruction_box" name="query_instruction" value="<%= @the_recipe_step.instruction %>">
    </div>

    <button type="submit">
      Update recipe step
    </button>
  </form>
</article>

<hr>
