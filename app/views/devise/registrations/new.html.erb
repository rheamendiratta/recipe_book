<div class="auth-container">
  <h1>Create your account</h1>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <% resource.errors.full_messages.each do |msg| %>
      <div class="flash flash--error"><%= msg %></div>
    <% end %>
    <div class="form-group">
      <%= f.label :display_name, "Display Name", class: "form-label" %>
      <%= f.text_field :display_name, autofocus: true, class: "form-input", placeholder: "How should we call you?" %>
    </div>
    <div class="form-group">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autocomplete: "email", class: "form-input" %>
    </div>
    <div class="form-group">
      <%= f.label :password, class: "form-label" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-input" %>
    </div>
    <div class="form-group">
      <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
    </div>
    <div class="form-actions">
      <%= f.submit "Sign up", class: "btn btn--primary" %>
    </div>
  <% end %>
  <p class="text-sm mt-md"><%= link_to "Already have an account? Sign in", new_user_session_path %></p>
</div>
