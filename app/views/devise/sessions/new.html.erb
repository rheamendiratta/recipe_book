<div class="auth-container">
  <h1>Welcome back</h1>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="form-group">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
    </div>
    <div class="form-group">
      <%= f.label :password, class: "form-label" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
    </div>
    <div class="form-group" style="display:flex; align-items:center; gap:var(--space-sm);">
      <%= f.check_box :remember_me %>
      <%= f.label :remember_me, style: "font-family:var(--font-ui); font-size:13px; cursor:pointer;" %>
    </div>
    <div class="form-actions">
      <%= f.submit "Sign in", class: "btn btn--primary" %>
    </div>
  <% end %>
  <p class="text-sm mt-md"><%= link_to "Don't have an account? Sign up", new_user_registration_path %></p>
  <p class="text-sm"><%= link_to "Forgot your password?", new_user_password_path %></p>
</div>
