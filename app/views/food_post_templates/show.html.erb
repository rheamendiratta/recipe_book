<p><a href="/feed">← Feed</a></p>

<article>
  <p>
    <strong><a href="/users/<%= @post.user_id %>"><%= @post.user.display %></a></strong>
    <small>— <%= time_ago_in_words(@post.created_at) %> ago</small>
  </p>

  <% if @post.photo.attached? %>
    <%= image_tag url_for(@post.photo), style: "max-width:600px; display:block;" %>
  <% elsif @post.photo_url.present? %>
    <img src="<%= @post.photo_url %>" style="max-width:600px; display:block;" alt="food photo">
  <% end %>

  <p><%= @post.caption %></p>

  <% if @post.recipe.present? %>
    <p>Recipe: <a href="/recipes/<%= @post.recipe_id %>"><%= @post.recipe.title %></a></p>
  <% end %>

  <p>
    <form action="/toggle_post_like/<%= @post.id %>" method="post" style="display:inline">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <button type="submit"><%= @liked ? "Unlike" : "Like" %></button>
    </form>
    <%= @like_count %> like<%= "s" if @like_count != 1 %>
  </p>

  <% if @post.user_id == current_user.id %>
    <p>
      <a href="/delete_food_post/<%= @post.id %>" data-turbo-confirm="Delete this post?">Delete post</a>
    </p>
  <% end %>
</article>

<hr>
<h3>Comments (<%= @comments.count %>)</h3>
<% @comments.each do |comment| %>
  <p>
    <strong><a href="/users/<%= comment.user_id %>"><%= comment.user.display %></a></strong>:
    <%= comment.comment_text %>
    <small>— <%= time_ago_in_words(comment.created_at) %> ago</small>
    <% if comment.user_id == current_user.id || @post.user_id == current_user.id %>
      <a href="/delete_post_comment/<%= comment.id %>">delete</a>
    <% end %>
  </p>
<% end %>

<form action="/insert_post_comment" method="post">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="hidden" name="query_post_id" value="<%= @post.id %>">
  <input type="text" name="query_comment_text" placeholder="Add a comment…" style="width:350px;" required>
  <button type="submit">Comment</button>
</form>
