<h1><%= @list.name %></h1>
<p><a href="/recipe_lists">← My Lists</a></p>

<form action="/modify_recipe_list/<%= @list.id %>" method="post">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="text" name="query_name" value="<%= @list.name %>" style="width:250px;" required>
  <button type="submit">Rename</button>
</form>

<hr>

<% if @items.empty? %>
  <p>No recipes in this list yet. <a href="/my_book">Browse your book</a> to add some.</p>
<% end %>

<% @items.each do |item| %>
  <% recipe = item.recipe %>
  <article style="border:1px solid #ccc; padding:8px; margin-bottom:8px;">
    <a href="/recipes/<%= recipe.id %>"><strong><%= recipe.title %></strong></a>
    <% if recipe.total_time_min %><small> — <%= recipe.total_time_display %></small><% end %>
    &nbsp;|&nbsp;
    <a href="/recipe_list_items/<%= item.id %>/remove">Remove from list</a>
  </article>
<% end %>
