<div class="page-header">
  <h1>My Lists</h1>
</div>

<div class="card" style="max-width:480px; margin-bottom:var(--space-xl);">
  <form action="/insert_recipe_list" method="post" style="display:flex; gap:var(--space-sm);">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <input type="text" name="query_name" class="form-input" placeholder="New list name…" required style="flex:1;">
    <button type="submit" class="btn btn--primary">Create</button>
  </form>
</div>

<% if @lists.empty? %>
  <div class="empty-state">
    <p>No lists yet. Create one to organise your recipes.</p>
  </div>
<% else %>
  <div class="book-grid">
    <% @lists.each do |list| %>
      <article class="book-item">
        <div class="book-item__thumb-placeholder">📋</div>
        <div class="book-item__content">
          <a href="/recipe_lists/<%= list.id %>" class="book-item__title"><%= list.name %></a>
          <p class="text-sm"><%= list.recipe_list_items.count %> recipe<%= "s" if list.recipe_list_items.count != 1 %></p>
        </div>
        <a href="/delete_recipe_list/<%= list.id %>" class="btn btn--ghost btn--sm" data-turbo-confirm="Delete this list?" style="margin-left:auto; align-self:center;">✕</a>
      </article>
    <% end %>
  </div>
<% end %>
