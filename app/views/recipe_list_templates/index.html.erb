<h1>My Recipe Lists</h1>

<form action="/insert_recipe_list" method="post">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <input type="text" name="query_name" placeholder="New list name…" required style="width:250px;">
  <button type="submit">Create List</button>
</form>

<hr>

<% if @lists.empty? %>
  <p>No lists yet. Create one above to organise your recipes.</p>
<% end %>

<% @lists.each do |list| %>
  <article style="border:1px solid #ccc; padding:8px; margin-bottom:8px;">
    <strong><a href="/recipe_lists/<%= list.id %>"><%= list.name %></a></strong>
    &nbsp;<small>(<%= list.recipe_list_items.count %> recipes)</small>
    &nbsp;|&nbsp;
    <a href="/delete_recipe_list/<%= list.id %>" data-turbo-confirm="Delete this list?">delete</a>
  </article>
<% end %>
