<h1>
  Recipe ingredient #<%= @the_recipe_ingredient.id %> details
</h1>

<article>
  <div>
    <a href="/recipe_ingredients">
      Go back
    </a>
  </div>

  <div>
    <a href="/delete_recipe_ingredient/<%= @the_recipe_ingredient.id %>">
      Delete recipe ingredient
    </a>
  </div>
  <dl>
    <dt>
      Recipe
    </dt>
    <dd>
      <%= @the_recipe_ingredient.recipe_id %>
    </dd>

    <dt>
      Component
    </dt>
    <dd>
      <%= @the_recipe_ingredient.component_id %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_ingredient.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_ingredient.updated_at) %> ago
    </dd>
  </dl>
</article>

<hr>


<article>
  <header>
    <h2>
      Edit recipe ingredient
    </h2>
  </header>

  <form action="/modify_recipe_ingredient/<%= @the_recipe_ingredient.id %>"  method="post" >
    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id" value="<%= @the_recipe_ingredient.recipe_id %>">
    </div>

    <div>
      <label for="component_id_box">
        Component
      </label>

      <input type="text" id="component_id_box" name="query_component_id" value="<%= @the_recipe_ingredient.component_id %>">
    </div>

    <button type="submit">
      Update recipe ingredient
    </button>
  </form>
</article>

<hr>
