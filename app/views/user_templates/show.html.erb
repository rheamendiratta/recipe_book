<a href="/users" class="back-link">← Find People</a>

<div class="user-card">
  <div class="user-avatar-large"><%= @user.display.first.upcase %></div>
  <div>
    <h2 style="margin-bottom:var(--space-xs);"><%= @user.display %></h2>
    <p class="text-sm"><%= @user.email %></p>
  </div>
  <div style="margin-left:auto;" class="action-row">
    <% if @user == current_user %>
      <a href="/users/edit" class="btn btn--secondary btn--sm">Edit Profile</a>
    <% elsif @friendship.nil? %>
      <form action="/friendships/request/<%= @user.id %>" method="post" style="display:inline">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit" class="btn btn--primary btn--sm">Add Friend</button>
      </form>
    <% elsif @friendship.accepted? %>
      <a href="/users/<%= @user.id %>/book" class="btn btn--secondary btn--sm">View Recipe Book</a>
    <% elsif @friendship.pending? && @friendship.requester_id == current_user.id %>
      <span class="text-sm">Request sent</span>
      <a href="/friendships/withdraw/<%= @friendship.id %>" class="btn btn--ghost btn--sm">Withdraw</a>
    <% elsif @friendship.pending? %>
      <form action="/friendships/accept/<%= @friendship.id %>" method="post" style="display:inline">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit" class="btn btn--primary btn--sm">Accept</button>
      </form>
      <form action="/friendships/decline/<%= @friendship.id %>" method="post" style="display:inline">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit" class="btn btn--secondary btn--sm">Decline</button>
      </form>
    <% end %>
  </div>
</div>

<% if @recent_posts %>
  <div class="section-divider">Recent Posts</div>
  <% if @recent_posts.empty? %>
    <p class="text-sm">No posts yet.</p>
  <% else %>
    <div class="photo-grid">
      <% @recent_posts.each do |post| %>
        <a href="/posts/<%= post.id %>" class="photo-grid__item">
          <% if post.photo.attached? %>
            <%= image_tag url_for(post.photo), alt: post.caption %>
          <% elsif post.photo_url.present? %>
            <img src="<%= post.photo_url %>" alt="<%= post.caption %>">
          <% end %>
        </a>
      <% end %>
    </div>
  <% end %>
<% end %>
