<h1>
  Friendship #<%= @the_friendship.id %> details
</h1>

<article>
  <div>
    <a href="/friendships">
      Go back
    </a>
  </div>

  <div>
    <a href="/delete_friendship/<%= @the_friendship.id %>">
      Delete friendship
    </a>
  </div>
  <dl>
    <dt>
      Requester
    </dt>
    <dd>
      <%= @the_friendship.requester_id %>
    </dd>

    <dt>
      Addressee
    </dt>
    <dd>
      <%= @the_friendship.addressee_id %>
    </dd>

    <dt>
      Status
    </dt>
    <dd>
      <%= @the_friendship.status %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_friendship.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_friendship.updated_at) %> ago
    </dd>
  </dl>
</article>

<hr>


<article>
  <header>
    <h2>
      Edit friendship
    </h2>
  </header>

  <form action="/modify_friendship/<%= @the_friendship.id %>"  method="post" >
    <div>
      <label for="requester_id_box">
        Requester
      </label>

      <input type="text" id="requester_id_box" name="query_requester_id" value="<%= @the_friendship.requester_id %>">
    </div>

    <div>
      <label for="addressee_id_box">
        Addressee
      </label>

      <input type="text" id="addressee_id_box" name="query_addressee_id" value="<%= @the_friendship.addressee_id %>">
    </div>

    <div>
      <label for="status_box">
        Status
      </label>

      <input type="text" id="status_box" name="query_status" value="<%= @the_friendship.status %>">
    </div>

    <button type="submit">
      Update friendship
    </button>
  </form>
</article>

<hr>
