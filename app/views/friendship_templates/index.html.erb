<h1>Friends</h1>

<% if @pending_received.any? %>
  <h3>Pending Requests (<%= @pending_received.count %>)</h3>
  <% @pending_received.each do |f| %>
    <p>
      <strong><a href="/users/<%= f.requester_id %>"><%= f.requester.display %></a></strong> sent you a friend request.
      <form action="/friendships/accept/<%= f.id %>" method="post" style="display:inline">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit">Accept</button>
      </form>
      <form action="/friendships/decline/<%= f.id %>" method="post" style="display:inline">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit">Decline</button>
      </form>
    </p>
  <% end %>
  <hr>
<% end %>

<% if @pending_sent.any? %>
  <h3>Sent Requests</h3>
  <% @pending_sent.each do |f| %>
    <p>
      Waiting on <strong><a href="/users/<%= f.addressee_id %>"><%= f.addressee.display %></a></strong>
      &nbsp;—&nbsp;
      <a href="/friendships/withdraw/<%= f.id %>">Withdraw</a>
    </p>
  <% end %>
  <hr>
<% end %>

<h3>Your Friends (<%= @friends.count %>)</h3>
<% if @friends.empty? %>
  <p>No friends yet. <a href="/users">Find people</a> to add.</p>
<% else %>
  <% @friends.each do |friend| %>
    <p>
      <strong><a href="/users/<%= friend.id %>"><%= friend.display %></a></strong>
      &nbsp;|&nbsp;
      <a href="/users/<%= friend.id %>/book">View their recipe book</a>
    </p>
  <% end %>
<% end %>
