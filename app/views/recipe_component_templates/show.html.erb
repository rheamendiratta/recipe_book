<h1>
  Recipe component #<%= @the_recipe_component.id %> details
</h1>

<article>
  <div>
    <a href="/recipe_components">
      Go back
    </a>
  </div>

  <div>
    <a href="/delete_recipe_component/<%= @the_recipe_component.id %>">
      Delete recipe component
    </a>
  </div>
  <dl>
    <dt>
      Recipe
    </dt>
    <dd>
      <%= @the_recipe_component.recipe_id %>
    </dd>

    <dt>
      Name
    </dt>
    <dd>
      <%= @the_recipe_component.name %>
    </dd>

    <dt>
      Sort order
    </dt>
    <dd>
      <%= @the_recipe_component.sort_order %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_component.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_component.updated_at) %> ago
    </dd>
  </dl>
</article>

<hr>


<article>
  <header>
    <h2>
      Edit recipe component
    </h2>
  </header>

  <form action="/modify_recipe_component/<%= @the_recipe_component.id %>"  method="post" >
    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id" value="<%= @the_recipe_component.recipe_id %>">
    </div>

    <div>
      <label for="name_box">
        Name
      </label>

      <input type="text" id="name_box" name="query_name" value="<%= @the_recipe_component.name %>">
    </div>

    <div>
      <label for="sort_order_box">
        Sort order
      </label>

      <input type="text" id="sort_order_box" name="query_sort_order" value="<%= @the_recipe_component.sort_order %>">
    </div>

    <button type="submit">
      Update recipe component
    </button>
  </form>
</article>

<hr>
