<h1>
  List of all recipe components
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new recipe component
    </h2>
  </header>

  <form action="/insert_recipe_component" method="post">
    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id">
    </div>

    <div>
      <label for="name_box">
        Name
      </label>

      <input type="text" id="name_box" name="query_name">
    </div>

    <div>
      <label for="sort_order_box">
        Sort order
      </label>

      <input type="text" id="sort_order_box" name="query_sort_order">
    </div>

    <button type="submit">
      Create recipe component
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_recipe_components.each do |a_recipe_component| %>
      <li>
        <a href="/recipe_components/<%= a_recipe_component.id %>">
          Recipe component #<%= a_recipe_component.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
