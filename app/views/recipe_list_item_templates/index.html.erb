<h1>
  List of all recipe list items
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new recipe list item
    </h2>
  </header>

  <form action="/insert_recipe_list_item" method="post">
    <div>
      <label for="list_id_box">
        List
      </label>

      <input type="text" id="list_id_box" name="query_list_id">
    </div>

    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id">
    </div>

    <button type="submit">
      Create recipe list item
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_recipe_list_items.each do |a_recipe_list_item| %>
      <li>
        <a href="/recipe_list_items/<%= a_recipe_list_item.id %>">
          Recipe list item #<%= a_recipe_list_item.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
