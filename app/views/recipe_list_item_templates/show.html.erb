<h1>
  Recipe list item #<%= @the_recipe_list_item.id %> details
</h1>

<article>
  <div>
    <a href="/recipe_list_items">
      Go back
    </a>
  </div>

  <div>
    <a href="/delete_recipe_list_item/<%= @the_recipe_list_item.id %>">
      Delete recipe list item
    </a>
  </div>
  <dl>
    <dt>
      List
    </dt>
    <dd>
      <%= @the_recipe_list_item.list_id %>
    </dd>

    <dt>
      Recipe
    </dt>
    <dd>
      <%= @the_recipe_list_item.recipe_id %>
    </dd>

    <dt>
      Created at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_list_item.created_at) %> ago
    </dd>

    <dt>
      Updated at
    </dt>
    <dd>
      <%= time_ago_in_words(@the_recipe_list_item.updated_at) %> ago
    </dd>
  </dl>
</article>

<hr>


<article>
  <header>
    <h2>
      Edit recipe list item
    </h2>
  </header>

  <form action="/modify_recipe_list_item/<%= @the_recipe_list_item.id %>"  method="post" >
    <div>
      <label for="list_id_box">
        List
      </label>

      <input type="text" id="list_id_box" name="query_list_id" value="<%= @the_recipe_list_item.list_id %>">
    </div>

    <div>
      <label for="recipe_id_box">
        Recipe
      </label>

      <input type="text" id="recipe_id_box" name="query_recipe_id" value="<%= @the_recipe_list_item.recipe_id %>">
    </div>

    <button type="submit">
      Update recipe list item
    </button>
  </form>
</article>

<hr>
